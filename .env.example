# Supabase — get these from your project's Settings > API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic API key — set this as a secret in your Supabase Edge Function, NOT here
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY is server-side only and must never appear in client code
